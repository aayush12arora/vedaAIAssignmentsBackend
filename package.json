{
  "name": "vedaai-backend",
  "version": "1.0.0",
  "description": "AI Assessment Creator Backend - VedaAI",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "npm run dev:all",
    "dev:all": "concurrently -k -n REDIS,API -c yellow,cyan \"npm run dev:redis\" \"npm run dev:server\"",
    "dev:server": "nodemon src/server.js",
    "dev:redis": "node start-redis-windows.js",
    "dev:no-redis": "nodemon src/server.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bullmq": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.14.0",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "ai",
    "assessment",
    "education"
  ],
